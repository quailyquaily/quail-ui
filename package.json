{
  "name": "quail-ui",
  "version": "0.9.2",
  "type": "module",
  "files": [
    "dist"
  ],
  "license": "AGPL-3.0",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./style.css": "./dist/index.css",
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build --mode lib",
    "build:demo": "vue-tsc && vite build --mode demo",
    "prepack": "pnpm build",
    "preview": "vite preview"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "quail-js": "^0.3.18",
    "vue": "^3.5.26",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.5",
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-vue": "^5.2.4",
    "rollup-plugin-scss": "^4.0.0",
    "sass": "^1.97.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vue-tsc": "^2.2.12"
  }
}
